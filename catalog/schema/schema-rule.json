{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Eco Rule v2",
  "type": "object",
  "required": [
    "id",
    "title",
    "summary",
    "category_code",
    "family_code",
    "layer",
    "tier",
    "severity",
    "ontology"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ECO-[A-Z0-9]+-[A-Z0-9]+-[0-9]{3}$"
    },
    "canonical_id": {
      "type": "string",
      "pattern": "^ECO-[A-Z0-9]+-[A-Z0-9]+-[0-9]{3}$"
    },
    "legacy_id": {
      "type": "string",
      "pattern": "^ECO-[A-Z0-9-]+-[0-9]{3}$"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1,
      "maximum": 999
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "category_code": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "family_code": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2,8}$"
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "family": {
      "type": "string",
      "minLength": 1
    },
    "layer": {
      "type": "string",
      "enum": [
        "ui",
        "application",
        "service",
        "data",
        "network",
        "platform",
        "infrastructure",
        "organization"
      ]
    },
    "tier": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4
    },
    "severity": {
      "type": "string"
    },
    "enabled_by_default": {
      "type": "boolean"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rationale": {
      "type": "string"
    },
    "impact": {
      "type": "object"
    },
    "detection": {
      "type": "object"
    },
    "remediation": {
      "type": "object"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "ontology": {
      "type": "object",
      "required": [
        "system_layers"
      ],
      "properties": {
        "category_code": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "family_code": {
          "type": "string",
          "pattern": "^[A-Z0-9]{2,8}$"
        },
        "lifecycle_stage": {
          "type": "string"
        },
        "system_layers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resource_impacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mechanisms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "detection_methods": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "remediation_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
