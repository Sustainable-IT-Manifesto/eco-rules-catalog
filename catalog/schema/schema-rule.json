{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Eco Rule",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "summary": { "type": "string" },
    "category_code": { "type": "string" },
    "family_code": { "type": "string" },
    "layer": {
      "type": "string",
      "enum": ["ai", "architecture", "code", "data", "network", "process"]
    },
    "ontology": {
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "family": { "type": "string" },
        "system_layers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["ai", "architecture", "code", "data", "network", "process"]
          }
        }
      },
      "additionalProperties": true
    },
    "impact": { "type": "object" },
    "detection": { "type": "object" },
    "remediation": { "type": "object" },
    "metadata": { "type": "object" },
    "examples": {
      "type": "object",
      "properties": {
        "pattern": {
          "type": "array",
          "items": { "$ref": "#/$defs/exampleItem" }
        },
        "remediation": {
          "type": "array",
          "items": { "$ref": "#/$defs/exampleItem" }
        }
      },
      "additionalProperties": false
    },
    "scanner_override": {
      "type": "object",
      "properties": {
        "targets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scope": {
          "type": "string",
          "enum": [
            "file",
            "manifest",
            "repo"
          ]
        },
        "file_globs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "file_names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "path_hints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "repo_signals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "manifest_kinds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "parser": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["id", "layer"],
  "additionalProperties": true,
  "$defs": {
    "exampleItem": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["title", "description"],
      "additionalProperties": false
    }
  }
}
