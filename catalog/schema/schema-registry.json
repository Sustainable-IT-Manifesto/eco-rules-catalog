{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Eco Registry",
  "type": "object",
  "required": [
    "version",
    "categories",
    "families",
    "system_layers",
    "statuses"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "id_pattern": {
      "type": "string"
    },
    "categories": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "name",
          "description",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "families": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "name",
          "category_code",
          "description",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "category_code": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "lifecycle_stages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "system_layers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "statuses": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
