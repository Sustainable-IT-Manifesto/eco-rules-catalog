@prefix eco: <https://example.org/eco#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

eco:Ontology a owl:Ontology ;
  rdfs:label "Eco Rules Ontology" ;
  rdfs:comment "Ontology for software inefficiency patterns and their impacts, detection, and remediation." .

eco:Rule a owl:Class .
eco:ResourceImpact a owl:Class .
eco:Mechanism a owl:Class .
eco:SystemLayer a owl:Class .
eco:DetectionMethod a owl:Class .
eco:RemediationPattern a owl:Class .

eco:affects a owl:ObjectProperty ; rdfs:domain eco:Rule ; rdfs:range eco:ResourceImpact .
eco:causedBy a owl:ObjectProperty ; rdfs:domain eco:Rule ; rdfs:range eco:Mechanism .
eco:occursIn a owl:ObjectProperty ; rdfs:domain eco:Rule ; rdfs:range eco:SystemLayer .
eco:detectedBy a owl:ObjectProperty ; rdfs:domain eco:Rule ; rdfs:range eco:DetectionMethod .
eco:correctedBy a owl:ObjectProperty ; rdfs:domain eco:Rule ; rdfs:range eco:RemediationPattern .
