{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Eco Rules Catalog",
  "type": "object",
  "required": [
    "catalog_version",
    "rules"
  ],
  "properties": {
    "catalog_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "publisher": {
      "type": "object"
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "./schema-rule.json"
      }
    }
  },
  "additionalProperties": true
}