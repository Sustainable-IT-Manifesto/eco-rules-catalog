{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Eco Family Registry",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "name",
      "code",
      "category",
      "description"
    ],
    "properties": {
      "name": {
        "type": "string",
        "minLength": 1
      },
      "code": {
        "type": "string",
        "pattern": "^[A-Z0-9]{2,6}$"
      },
      "category": {
        "type": "string",
        "minLength": 1
      },
      "description": {
        "type": "string",
        "minLength": 1
      }
    },
    "additionalProperties": false
  }
}