{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Eco Rule",
  "type": "object",
  "required": [
    "id",
    "title",
    "summary",
    "category",
    "category_code",
    "family",
    "family_code",
    "layer",
    "tier",
    "severity"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ECO-[A-Z0-9]+-\\d{3}$"
    },
    "canonical_id": {
      "type": "string",
      "pattern": "^ECO-[A-Z]+-[A-Z0-9]+-\\d{3}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "category_code": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "family": {
      "type": "string",
      "minLength": 1
    },
    "family_code": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2,6}$"
    },
    "layer": {
      "type": "string",
      "enum": [
        "Code",
        "Runtime",
        "Data",
        "Network",
        "Architecture",
        "AI/ML",
        "Organizational"
      ]
    },
    "tier": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4
    },
    "severity": {
      "type": "string",
      "enum": [
        "note",
        "warning",
        "error",
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rationale": {
      "type": "string"
    },
    "impact": {
      "type": "object"
    },
    "detection": {
      "type": "object"
    },
    "remediation": {
      "type": "object"
    },
    "ontology": {
      "type": "object",
      "properties": {
        "resource_impacts": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "CPU",
              "Memory",
              "Network",
              "Storage",
              "Energy",
              "Latency",
              "Infrastructure Cost",
              "Developer Time"
            ]
          }
        },
        "mechanisms": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Redundant Computation",
              "Excessive Allocation",
              "Inefficient Data Structures",
              "Serialization Overhead",
              "Network Amplification",
              "Polling",
              "Cache Misuse",
              "Unbounded Growth",
              "Resource Contention",
              "Over-Provisioning"
            ]
          }
        },
        "system_layers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Code",
              "Runtime",
              "Data",
              "Network",
              "Architecture",
              "AI/ML",
              "Organizational"
            ]
          }
        },
        "detection_methods": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Static Analysis",
              "Runtime Profiling",
              "Query Analysis",
              "Network Trace Analysis",
              "Log Pattern Detection",
              "CI Pipeline Inspection"
            ]
          }
        },
        "remediation_patterns": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Algorithmic Improvement",
              "Resource Reuse",
              "Caching",
              "Batching",
              "Event-Driven Design",
              "Data Reduction",
              "Infrastructure Right-Sizing"
            ]
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}